# Server port (config.ts reads PORT; default 3001)
PORT=3001
DB_PATH=~/.subagent-manager/data.db

# ── Deployment (docker-compose / Kubernetes) ────────────────────────────
# Set DATABASE_URL to switch from the default SQLite to Postgres. Compose reads
# these to provision the sidecar postgres:
POSTGRES_USER=agenticbear
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=agenticbear
# Full URL — used by the server. Compose builds this from the three above.
# DATABASE_URL=postgres://agenticbear:change-me-please@postgres:5432/agenticbear

# Auth HMAC secret — signs & verifies session tokens (config.ts reads AUTH_SECRET).
# In hub topology this MUST be shared by the hub and all session pods. 32+ random bytes.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
AUTH_SECRET=please-generate-a-real-secret-before-going-anywhere-near-prod

# ── Hub topology (Kubernetes: control-plane pod + one session pod per user) ──
# AGB_MODE=standalone   # default: everything in one process (local dev, single pod)
# AGB_MODE=hub          # control plane: auth/SPA/gateway/MCP + session-pod orchestration
# AGB_MODE=session      # one user's agentic runtime (created by the hub, not by hand)
# Hub-mode knobs (kubernetes backend needs in-cluster RBAC — see deploy/helm):
# AGB_SESSION_BACKEND=kubernetes        # or "process" (dev: child processes, no cluster)
# AGB_SESSION_IMAGE=agenticbear:latest  # image for session pods (required for kubernetes)
# AGB_NAMESPACE=                        # default: the hub's own namespace
# AGB_SESSION_TTL_SECONDS=1800          # idle TTL before a session pod is reaped
# AGB_SESSION_READY_TIMEOUT_SECONDS=120
# AGB_SESSION_CPU_REQUEST=250m / AGB_SESSION_CPU_LIMIT=1
# AGB_SESSION_MEM_REQUEST=512Mi / AGB_SESSION_MEM_LIMIT=2Gi
# AGB_SESSION_CONFIGMAP= / AGB_SESSION_SECRET=   # envFrom refs injected into session pods
# AGB_SESSION_NFS_SERVER= / AGB_SESSION_NFS_PATH=   # opsiyonel: session /workspace'leri NFS'te
#   (her kullanıcıya <path>/<username>/ alt dizini; git clone'lar orada, pod silinse de kalır)
# AGB_INGRESS_CLASS=nginx
# AGB_PUBLIC_HOST=agenticbear.local     # host the per-user /u/<hash> Ingress rules attach to
# AGB_SESSION_BASE_PREFIX=/u
# Session-mode (injected by the hub): AGB_SESSION_USER_ID=<uid>

# Optional: disable the built-in issue-tracker inbound pull scheduler
# ISSUE_PULL_INTERVAL_MS=0     # 0 disables; default 300000 (5 min); hub forces 0 in session pods


# MCP — ek provider API key'leri (Anthropic için Settings sayfası önceliklidir)
ANTHROPIC_API_KEY=        # Fallback — Settings'te tanımlı değilse kullanılır
OPENAI_API_KEY=           # OpenAI modelleri için (gpt-4o, o3, vb.)
GEMINI_API_KEY=           # Google Gemini modelleri için

# ── Cost Layer (LLM maliyet middleware) ──────────────────────────────
# Katman flag'leri (varsayılan: üçü de açık)
COST_LAYER_SEMANTIC_CACHE=true
COST_LAYER_ROUTER=true
COST_LAYER_PROMPT_CACHE=true
# L1 Semantic Cache (Qdrant + embedding)
# Embedder seçimi — gemini varsayılan, mevcut Gemini key'iyle (settings veya env) çalışır.
COST_EMBEDDING_PROVIDER=gemini        # gemini | voyage | openai | local
COST_QDRANT_URL=http://localhost:6333
COST_SEMANTIC_THRESHOLD=0.95          # üretimde 0.95+ ile başla, ölçerek indir
COST_SEMANTIC_TTL_SECONDS=86400
# COST_GEMINI_EMBEDDING_MODEL=text-embedding-004      # gemini için (default)
# COST_OPENAI_EMBEDDING_MODEL=text-embedding-3-small  # openai için (default)
# VOYAGE_API_KEY=                                     # voyage seçtiğinde gerekir
# L2 Router
COST_ROUTER_CHEAP_MODEL=claude-haiku-4-5-20251001
# L3 Prompt Cache
COST_PROMPT_CACHE_TTL=5m              # 5m | 1h (1h bu SDK sürümünde 5m'e düşer)
